# ════════════════════════════════════════════════════════════════
#  FitNest v2.1 — Server Environment Variables
#  Copy to server/.env for local dev.
#  On Render: add these in the Environment tab.
# ════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/fitnest?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_here_use_openssl_rand_hex_32
JWT_EXPIRE=30d

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@fitnest.com

# ── Google Fit / OAuth 2.0 ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/googlefit/callback

# ── Health Connect Web Bridge (Android 14+ live sync) ────────────
# Required for navigator.health to activate in Chrome on Android.
# 1. Go to: https://developer.chrome.com/origintrials/#/trials/active
# 2. Search "Health" → find "Web app access to health data on Android"
# 3. Register your deployed URL (e.g. https://your-app.onrender.com)
# 4. Copy the token here. Without this, Android users get manual entry only.
HEALTH_CONNECT_OT_TOKEN=

# ── IFCT2017 ────────────────────────────────────────────────────
IFCT_ENABLED=true

# ── CORS (production frontend URL) ──────────────────────────────
FRONTEND_URL=https://your-frontend.onrender.com
