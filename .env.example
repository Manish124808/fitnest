# Root-level .env (server also loads this as fallback)
# Primary: copy server/.env.example to server/.env

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/fitnest
JWT_SECRET=generate_with__node_-e__console.log(require('crypto').randomBytes(32).toString('hex'))
JWT_EXPIRE=30d
ADMIN_EMAIL=admin@yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/googlefit/callback
FRONTEND_URL=http://localhost:5173
IFCT_ENABLED=true
